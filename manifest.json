{
  "manifest_version": 3,
  "name": "DevHub",
  "version": "1.0.0",
  "description": "API vault, snippets, docs, and AI assistant for developers",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "dist/popup.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  }
}
